page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 32rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 32rpx 40rpx;
  margin-bottom: 32rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.section-body {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #27AE60;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
}

.stat-warning {
  color: #FFC107;
}

.stat-danger {
  color: #F39C12;
}

.stat-active {
  color: #27AE60;
}

.stat-ended {
  color: #999999;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 32rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.card-body {
  display: flex;
  justify-content: space-around;
}

.button {
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  transition: all 0.3s;
}

.button-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.button-primary:active {
  opacity: 0.8;
}

.button-default {
  background: #f0f0f0;
  color: #333333;
}

.button-default:active {
  background: #e0e0e0;
}

.button-danger {
  background: #F39C12;
  color: #ffffff;
}

.button-danger:active {
  opacity: 0.8;
}

.button-success {
  background: #27AE60;
  color: #ffffff;
}

.button-success:active {
  opacity: 0.8;
}

.button-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.button-large {
  padding: 32rpx 64rpx;
  font-size: 32rpx;
}

.input {
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 24rpx;
  color: #333333;
  margin-bottom: 12rpx;
  font-weight: bold;
}

.input-placeholder {
  color: #999999;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.tag-success {
  background: #e8f5e9;
  color: #27AE60;
}

.tag-warning {
  background: #fff7e6;
  color: #FFC107;
}

.tag-danger {
  background: #ffebee8;
  color: #F39C12;
}

.tag-default {
  background: #f0f0f0;
  color: #666666;
}

.text-primary {
  color: #27AE60;
}

.text-success {
  color: #27AE60;
}

.text-warning {
  color: #FFC107;
}

.text-danger {
  color: #F39C12;
}

.text-secondary {
  color: #666666;
}

.text-muted {
  color: #999999;
}

.divider {
  height: 1rpx;
  background: #e0e0e0;
  margin: 32rpx 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  min-height: 400rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: #cccccc;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  min-height: 400rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e0e0e0;
  border-top: 4rpx solid #27AE60;
  border-radius: 50%;
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.nav-bar {
  background: #ffffff;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.nav-bar-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
}

.nav-bar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-bar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-bar-button {
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: transparent;
  color: #333333;
  border: none;
}

.nav-bar-button:active {
  background: #f0f0f0;
}

.scroll-container {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.list-item {
  background: #ffffff;
  padding: 32rpx;
  border-bottom: 1rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background 0.3s;
}

.list-item:active {
  background: #f9f9f9;
}

.list-item-content {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.list-item-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.list-item-subtitle {
  font-size: 24rpx;
  color: #666666;
}

.list-item-meta {
  font-size: 24rpx;
  color: #999999;
}

.list-item-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dialog {
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.dialog-content {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.dialog-close {
  font-size: 48rpx;
  color: #999999;
  padding: 16rpx;
  border: none;
  background: transparent;
}

.dialog-body {
  margin-bottom: 32rpx;
}

.dialog-footer {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.flex-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.flex-col {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.grid-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  text-align: center;
  transition: all 0.3s;
}

.grid-item:active {
  transform: scale(1.05);
  box-shadow: 0 8rpx 16rpx rgba(39, 174, 96, 0.2);
}

.grid-item-icon {
  font-size: 64rpx;
  color: #27AE60;
  margin-bottom: 16rpx;
}

.grid-item-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.grid-item-desc {
  font-size: 24rpx;
  color: #666666;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
}