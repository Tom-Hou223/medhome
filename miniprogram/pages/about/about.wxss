.about-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 32rpx;
  padding-top: calc(var(--status-bar-height) + 160rpx + 32rpx);
}

.about-content {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 56rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
  padding-bottom: 48rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.app-name {
  font-size: 42rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.app-version {
  font-size: 26rpx;
  color: #999999;
  background-color: #f8f8f8;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.info-section {
  margin-bottom: 64rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.description-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.description-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.description-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
  text-align: justify;
  padding: 24rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
}

.copyright-section {
  margin-top: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #f5f5f5;
}

.copyright-text {
  font-size: 22rpx;
  color: #999999;
}

.company-info {
  font-size: 22rpx;
  color: #999999;
}