.statistics-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx;
  padding-top: calc(var(--status-bar-height) + 88rpx + 32rpx);
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #999999;
}

.content {
  margin-top: 32rpx;
}

.stats-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.stat-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #27AE60;
}

.stat-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
}

.stat-number {
  font-size: 32rpx;
  font-weight: bold;
}

.stat-normal {
  color: #27AE60;
}

.stat-warning {
  color: #FFC107;
}

.stat-danger {
  color: #F39C12;
}

.stat-success {
  color: #27AE60;
}

.chart-card {
  min-height: 480rpx;
}

.chart-container {
  width: 100%;
  height: 480rpx;
}

.expiry-chart {
  width: 100%;
  height: 100%;
}

.plan-chart {
  width: 100%;
  height: 100%;
}

.loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 50;
}

.tab-content {
  margin-top: 32rpx;
}