/* 老年模式设置页面样式 */
.settings-container.senior-mode {
  font-size: 36rpx !important;
  padding-bottom: 180rpx;
}

.settings-container.senior-mode .section-title {
  font-size: 40rpx !important;
  font-weight: bold !important;
  padding: 24rpx 32rpx !important;
}

.settings-container.senior-mode .van-cell {
  font-size: 36rpx !important;
  min-height: 120rpx !important;
  padding: 32rpx !important;
}

.settings-container.senior-mode .van-cell__title {
  font-size: 36rpx !important;
}

.settings-container.senior-mode .van-cell__value {
  font-size: 36rpx !important;
}

.settings-container.senior-mode .van-button {
  height: 100rpx !important;
  font-size: 36rpx !important;
  font-weight: bold !important;
}

.settings-container.senior-mode .van-switch {
  transform: scale(1.3) !important;
}

/* 黑底黄字主题 */
.settings-container.senior-mode.theme-yellow {
  background-color: #000000 !important;
}

.settings-container.senior-mode.theme-yellow .settings-section {
  background-color: #1a1a1a !important;
}

.settings-container.senior-mode.theme-yellow .section-title {
  color: #FFD700 !important;
}

.settings-container.senior-mode.theme-yellow .van-cell-group {
  background-color: #1a1a1a !important;
}

.settings-container.senior-mode.theme-yellow .van-cell {
  background-color: #1a1a1a !important;
  color: #FFD700 !important;
  border-bottom: 1rpx solid #333333 !important;
}

.settings-container.senior-mode.theme-yellow .van-cell__title {
  color: #FFD700 !important;
}

.settings-container.senior-mode.theme-yellow .van-cell__value {
  color: #FFD700 !important;
}

.settings-container.senior-mode.theme-yellow .van-button--primary {
  background-color: #FFD700 !important;
  color: #000000 !important;
  border: none !important;
}

.settings-container.senior-mode.theme-yellow .van-button--default {
  background-color: #333333 !important;
  color: #FFD700 !important;
  border: 2rpx solid #FFD700 !important;
}

.settings-container.senior-mode.theme-yellow .actions {
  padding: 32rpx !important;
}

