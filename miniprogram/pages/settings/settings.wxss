@import "settings-senior.wxss";

.settings-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 32rpx;
  padding-top: calc(var(--status-bar-height) + 88rpx + 32rpx);
  padding-bottom: 160rpx;
}

.settings-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.actions {
  margin-top: 40rpx;
}

/* 时间选择器样式 */
.time-picker-container {
  background-color: #fff;
  padding-bottom: 40rpx;
}

.time-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}

.time-picker-header text {
  font-size: 28rpx;
  color: #576b95;
}

.time-picker-header .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.time-picker-content {
  padding: 32rpx;
}

.time-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.time-item:last-child {
  border-bottom: none;
}

.time-item text {
  font-size: 28rpx;
  color: #333;
}

.time-item .picker {
  font-size: 28rpx;
  color: #576b95;
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}