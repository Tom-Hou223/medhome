<view class="feedback-container" style="--status-bar-height: {{statusBarHeight}}px">
  <nav-bar title="帮助与反馈" showBack="{{true}}" />
  <view class="form-section">
    <van-cell-group>
      <van-field
        label="反馈类型"
        placeholder="请选择反馈类型"
        value="{{formData.type}}"
        readonly
        is-link
        bindtap="showTypePicker"
        required
      />

      <van-field
        label="反馈内容"
        type="textarea"
        placeholder="请输入反馈内容"
        value="{{formData.content}}"
        bind:change="onContentInput"
        required
        autosize
      />

      <van-field
        label="联系方式"
        type="text"
        placeholder="请输入联系方式（选填）"
        value="{{formData.contact}}"
        bind:change="onContactInput"
      />
    </van-cell-group>
  </view>

  <view class="actions">
    <van-button type="primary" block bindtap="onSubmit">提交反馈</van-button>
  </view>
</view>