.profile-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx;
  padding-top: calc(var(--status-bar-height) + 88rpx + 32rpx);
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  position: relative;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: #f0f0f0;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  cursor: pointer;
}

.avatar-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: 50%;
}

.avatar:active .avatar-mask {
  opacity: 1;
}

.avatar-mask-text {
  color: #ffffff;
  font-size: 24rpx;
}

.avatar image {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0f0f0 0%, #e0e0e0 100%);
}

.avatar-placeholder image {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.7;
}

.avatar-upload-btn {
  margin-top: 16rpx;
  transition: all 0.3s ease;
}

.avatar-upload-btn:hover {
  transform: scale(1.05);
}

.form-section {
  margin-bottom: 40rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.actions {
  margin-top: 60rpx;
}

.actions button {
  font-size: 28rpx;
  height: 88rpx;
  border-radius: 12rpx;
}

.van-field {
  margin-bottom: 24rpx;
}

.van-field__control {
  font-size: 28rpx;
}

.van-field__label {
  font-size: 28rpx;
  width: 120rpx;
}