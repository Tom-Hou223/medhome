<view class="profile-container" style="--status-bar-height: {{statusBarHeight}}px">
  <nav-bar title="编辑资料" showBack="{{true}}" />

  <view class="avatar-section">
    <view class="avatar-wrapper">
      <view class="avatar" bindtap="onAvatarUpload">
        <image wx:if="{{tempAvatarPath}}" src="{{tempAvatarPath}}" mode="aspectFill" />
        <image wx:elif="{{formData.avatarUrl}}" src="{{formData.avatarUrl}}" mode="aspectFill" />
        <view class="avatar-placeholder" wx:else>
          <image src="/images/icon_pill.png" mode="aspectFit" />
        </view>
        <view class="avatar-mask">
          <text class="avatar-mask-text">点击更换</text>
        </view>
      </view>
      <van-button type="primary" size="small" icon="photo" bindtap="onAvatarUpload" class="avatar-upload-btn">更换头像</van-button>
    </view>
  </view>

  <view class="form-section">
    <van-cell-group>
      <van-field
        label="昵称"
        placeholder="请输入昵称"
        value="{{formData.nickname || ''}}"
        bind:input="onNicknameInput"
        required
      />

      <van-field
        label="手机号"
        type="number"
        placeholder="请输入手机号"
        value="{{formData.phone || ''}}"
        bind:input="onPhoneInput"
        maxlength="11"
      />
    </van-cell-group>
  </view>

  <view class="actions">
    <van-button type="primary" block bindtap="onSave">保存</van-button>
  </view>
</view>
