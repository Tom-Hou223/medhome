.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.content {
  padding: 120rpx 32rpx 20rpx 32rpx;
}

.section {
  margin-bottom: 40rpx;
}

.family-header {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.family-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
  display: flex;
  align-items: center;
}

.member-count {
  margin-left: 8rpx;
  color: #999;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.value.role-admin {
  color: #ff9800;
}

.value.role-member {
  color: #2196f3;
}

.invite-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.invite-content {
  text-align: center;
}

.invite-code {
  font-size: 48rpx;
  font-weight: bold;
  color: #27ae60;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.invite-tips {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.invite-actions {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.loading-container {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.member-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.member-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  overflow: hidden;
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.member-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.member-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.role-tag {
  font-size: 26rpx;
}

.role-tag.clickable {
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

.role-tag.admin {
  color: #ff9800;
}

.role-tag.member {
  color: #2196f3;
}

.join-time {
  font-size: 24rpx;
  color: #999;
}

.action-section {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
