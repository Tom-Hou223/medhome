.medicine-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
  padding-top: calc(var(--status-bar-height) + 88rpx + 32rpx);
}

.search-bar {
  padding: 16rpx 32rpx;
  background: #ffffff;
}

.medicine-list {
  padding: 32rpx;
}

.medicine-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.medicine-item:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.medicine-info {
  margin-bottom: 24rpx;
}

.medicine-header {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
  position: relative;
  padding-right: 80rpx;
}

.medicine-header .van-tag {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 1;
  margin-top: 4rpx;
}

.medicine-details {
  flex: 1;
  min-width: 0;
}

.medicine-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.medicine-dosage {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.medicine-spec-stock {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 4rpx;
}

.spec-text {
  font-size: 24rpx;
  color: #666666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stock-text {
  font-size: 24rpx;
  color: #666666;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.medicine-category {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.category-text {
  font-size: 22rpx;
  color: #999999;
  font-weight: 500;
}

.medicine-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.manufacturer-text {
  font-size: 22rpx;
  color: #999999;
  flex: 1;
}

.category-text {
  font-size: 22rpx;
  color: #999999;
  font-weight: 500;
}

.medicine-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.medicine-actions .van-icon {
  padding: 8rpx;
  transition: all 0.3s;
}

.medicine-actions .van-icon:active {
  transform: scale(1.2);
}

.empty-state {
  margin-top: 80rpx;
}

.add-button {
  position: fixed;
  bottom: 160rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 100;
}

.dialog-content {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 32rpx;
  overflow-y: auto;
}

.dialog-header {
  flex-shrink: 0;
  text-align: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #f9fafb;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.dialog-body {
  margin-bottom: 32rpx;
}

.dialog-footer {
  flex-shrink: 0;
  padding: 32rpx;
  padding-bottom: 120rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  gap: 16rpx;
}

/* 搜索操作区域 */
.search-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 拍照按钮 */
.scan-button {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  background-color: #f9fafb;
  border: 1rpx solid #e0e0e0;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
  cursor: pointer;
}

.scan-button:active {
  background-color: #f0f0f0;
  transform: scale(0.98);
}

.scan-icon {
  font-size: 24rpx;
}

.scan-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #666666;
}

/* 搜索按钮 */
.search-button {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  background-color: #3498DB;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s;
  cursor: pointer;
}

.search-button:active {
  background-color: #2980B9;
  transform: scale(0.98);
}

/* 日期选择器样式 */
.date-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.date-picker-cancel {
  font-size: 28rpx;
  color: #999999;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.date-picker-cancel:active {
  background-color: #f5f5f5;
}

.date-picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.date-picker-confirm {
  font-size: 28rpx;
  color: #27AE60;
  font-weight: 500;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.date-picker-confirm:active {
  background-color: rgba(39, 174, 96, 0.1);
}

/* 日历内容样式 */
.calendar-content {
  padding: 0;
  height: calc(100% - 100rpx);
  overflow: hidden;
}

.calendar-content .van-calendar {
  height: 100%;
}

.calendar-content .van-calendar__header {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.calendar-content .van-calendar__body {
  height: calc(100% - 120rpx);
}

.calendar-content .van-calendar__cell {
  height: 80rpx;
  line-height: 80rpx;
}

.calendar-content .van-calendar__cell--selected {
  background-color: #27AE60 !important;
  color: #ffffff !important;
}

.calendar-content .van-calendar__cell--start {
  background-color: #27AE60 !important;
  color: #ffffff !important;
}

.calendar-content .van-calendar__cell--end {
  background-color: #27AE60 !important;
  color: #ffffff !important;
}

.calendar-content .van-calendar__cell--range {
  background-color: rgba(39, 174, 96, 0.1) !important;
}