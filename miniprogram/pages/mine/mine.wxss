.mine-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-top: calc(var(--status-bar-height) + 88rpx + 32rpx);
  padding-bottom: 160rpx;
}

/* 老年模式容器 */
.mine-senior-container {
  min-height: 100vh;
  padding: 32rpx;
  padding-top: calc(var(--status-bar-height) + 88rpx + 32rpx);
  padding-bottom: 180rpx;
}

/* 白底黑字主题 */
.theme-white {
  background-color: #ffffff;
  color: #000000;
}

.theme-white .senior-user-card,
.theme-white .senior-family-card,
.theme-white .senior-menu-item {
  background-color: #f5f5f5;
  color: #000000;
}

.theme-white .user-name,
.theme-white .user-phone,
.theme-white .family-name,
.theme-white .menu-text {
  color: #000000;
}

.theme-white .senior-btn-logout {
  background-color: #ff4444;
  color: #ffffff;
}

/* 黑底黄字主题 */
.theme-yellow {
  background-color: #000000;
  color: #FFD700;
}

.theme-yellow .senior-user-card,
.theme-yellow .senior-family-card,
.theme-yellow .senior-menu-item {
  background-color: #1a1a1a;
  color: #FFD700;
  border: 2rpx solid #333333;
}

.theme-yellow .user-name,
.theme-yellow .user-phone,
.theme-yellow .family-name,
.theme-yellow .menu-text {
  color: #FFD700;
}

.theme-yellow .senior-btn-logout {
  background-color: #FFD700;
  color: #000000;
}

/* 用户卡片 */
.senior-user-card {
  padding: 48rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.1);
  font-size: 80rpx;
}

.theme-yellow .user-avatar {
  background-color: rgba(255, 215, 0, 0.2);
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-name {
  font-size: 48rpx;
  font-weight: bold;
}

.user-phone {
  font-size: 36rpx;
  opacity: 0.8;
}

/* 家庭卡片 */
.senior-family-card {
  padding: 40rpx 48rpx;
  border-radius: 24rpx;
  margin-bottom: 48rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.family-icon {
  font-size: 64rpx;
}

.family-name {
  font-size: 44rpx;
  font-weight: bold;
}

/* 菜单 */
.senior-menu {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
  margin-bottom: 48rpx;
}

.senior-menu-item {
  padding: 56rpx 32rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.menu-icon {
  font-size: 80rpx;
}

.menu-text {
  font-size: 36rpx;
  font-weight: bold;
}

/* 退出登录 */
.senior-logout {
  margin-top: 32rpx;
}

.senior-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 16rpx;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.senior-btn-logout {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.senior-btn-logout::after {
  border: none;
}

.user-info {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  padding: 56rpx 32rpx;
  margin: 0 32rpx 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(79, 172, 254, 0.3);
  position: relative;
  overflow: hidden;
}

.user-info::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 70%);
  transform: rotate(45deg);
}

.avatar-section {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.avatar-section:hover {
  transform: translateY(-2rpx);
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar image {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0.1) 100%);
}

.avatar-placeholder image {
  width: 70rpx;
  height: 70rpx;
  opacity: 0.9;
}

.user-details {
  flex: 1;
  margin-left: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  position: relative;
  z-index: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 4rpx;
}

.phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.guest-badge {
  font-size: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  align-self: flex-start;
  margin-bottom: 8rpx;
}

.user-role {
  font-size: 24rpx;
  color: #ff9800;
  font-weight: 500;
  margin-top: 4rpx;
}

/* 家庭信息 */
.family-info {
  margin-top: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

.family-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.family-main {
  display: flex;
  align-items: center;
}

.family-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(39, 174, 96, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.family-texts {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.family-name-text {
  color: #1f2d3d;
  font-size: 30rpx;
  font-weight: 600;
}

.family-role {
  margin-left: 24rpx;
}

.role-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(39, 174, 96, 0.08);
  color: #27ae60;
  border: 1rpx solid rgba(39, 174, 96, 0.3);
}

.role-tag.admin {
  background: rgba(255, 152, 0, 0.1);
  color: #ff9800;
  border-color: rgba(255, 152, 0, 0.4);
}

.role-tag.member {
  background: rgba(33, 150, 243, 0.1);
  color: #2196f3;
  border-color: rgba(33, 150, 243, 0.4);
}

.family-right {
  margin-left: auto;
  display: flex;
  align-items: center;
}



.settings-section {
  margin: 0 32rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-section {
  margin: 0 32rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.van-cell {
  border-radius: 12rpx;
  margin: 4rpx 0;
  transition: all 0.3s ease;
}

.van-cell:hover {
  background: #f5f9ff;
}

.version-info {
  text-align: center;
  padding: 48rpx 32rpx;
}

.version-text {
  font-size: 24rpx;
  color: #999999;
  background: #ffffff;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  display: inline-block;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}