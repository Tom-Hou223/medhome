.reminder-settings-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.content {
  padding: 24rpx 32rpx;
  padding-top: calc(var(--status-bar-height) + 88rpx + 24rpx);
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 48rpx;
}

.actions .van-button {
  flex: 1;
}