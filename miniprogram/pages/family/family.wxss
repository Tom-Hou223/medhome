.family-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f5f5 0%, #f0f9ff 100%);
  padding: 32rpx;
  padding-top: calc(var(--status-bar-height) + 88rpx + 32rpx);
}

.header {
  margin-bottom: 48rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #7f8c8d;
  line-height: 1.4;
}

.member-list {
  margin-bottom: 40rpx;
}

.member-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.member-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #27AE60 0%, #219A52 100%);
  border-radius: 6rpx 0 0 6rpx;
}

.member-item:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.member-avatar {
  width: 140rpx;
  height: 140rpx;
  margin-right: 36rpx;
  flex-shrink: 0;
  position: relative;
}

.avatar-container {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.3s ease;
}

.avatar-container:active {
  transform: scale(1.05);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #f0f0f0 0%, #e0e0e0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.member-item:active .avatar-placeholder {
  transform: scale(1.05);
}

.avatar-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.member-item:active .avatar-image {
  transform: scale(1.05);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.2);
}

.avatar-text {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #27AE60 0%, #219A52 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 48rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.member-item:active .avatar-text {
  transform: scale(1.05);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.2);
}

.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.member-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #2c3e50;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-name::after {
  content: '';
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  background: #27AE60;
  border-radius: 50%;
}

.member-relation {
  font-size: 26rpx;
  color: #546e7a;
  font-weight: 500;
}

.member-phone {
  font-size: 24rpx;
  color: #90a4ae;
  font-family: monospace;
  letter-spacing: 1rpx;
}

.member-actions {
  margin-left: 24rpx;
  position: relative;
  z-index: 10;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.edit-btn {
  background: rgba(39, 174, 96, 0.1);
}

.edit-btn:active {
  background: rgba(39, 174, 96, 0.2);
  transform: scale(1.1);
}

.delete-btn {
  background: rgba(231, 76, 60, 0.1);
}

.delete-btn:active {
  background: rgba(231, 76, 60, 0.2);
  transform: scale(1.1);
}

.member-actions .van-icon {
  font-size: 24rpx !important;
  transition: all 0.3s ease;
}

.empty-state {
  margin-top: 100rpx;
  text-align: center;
}

.add-button {
  position: fixed;
  bottom: 120rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 99;
}

.add-button .van-button {
  height: 92rpx !important;
  font-size: 28rpx !important;
  font-weight: bold !important;
  border-radius: 46rpx !important;
  background: linear-gradient(135deg, #27AE60 0%, #219A52 100%) !important;
  box-shadow: 0 8rpx 24rpx rgba(39, 174, 96, 0.3) !important;
  transition: all 0.3s ease !important;
  border: none !important;
}

.add-button .van-button:active {
  transform: scale(0.98) !important;
  box-shadow: 0 4rpx 16rpx rgba(39, 174, 96, 0.2) !important;
}

.dialog-content {
  flex: 1;
  padding: 36rpx;
  padding-bottom: 36rpx;
  overflow-y: auto;
}

.dialog-header {
  flex-shrink: 0;
  text-align: center;
  padding: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #f9fafb;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2c3e50;
  letter-spacing: 1rpx;
}

.dialog-body {
  margin-bottom: 36rpx;
}

.dialog-tips {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.dialog-footer {
  flex-shrink: 0;
  padding: 32rpx;
  padding-bottom: 220rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  gap: 20rpx;
}

.dialog-footer .van-button {
  flex: 1;
  height: 84rpx !important;
  font-size: 28rpx !important;
  font-weight: 500 !important;
  border-radius: 12rpx !important;
}

.dialog-footer .van-button--primary {
  background: linear-gradient(135deg, #27AE60 0%, #219A52 100%) !important;
  border: none !important;
}

.dialog-footer .van-button--primary:active {
  transform: scale(0.98) !important;
}

.dialog-footer .van-button--default {
  border: 2rpx solid #e0e0e0 !important;
  color: #7f8c8d !important;
}

.dialog-footer .van-button--default:active {
  background-color: #f5f5f5 !important;
  transform: scale(0.98) !important;
}

/* 自定义选择器样式 */
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #ffffff;
}

.picker-cancel, .picker-confirm {
  font-size: 28rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.picker-cancel {
  color: #7f8c8d;
}

.picker-cancel:active {
  background-color: #f5f5f5;
}

.picker-confirm {
  color: #27AE60;
  font-weight: bold;
}

.picker-confirm:active {
  background-color: rgba(39, 174, 96, 0.1);
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.picker-content {
  padding: 0;
  max-height: calc(100% - 80rpx);
  overflow-y: auto;
}

.picker-item {
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.3s;
  background-color: #ffffff;
}

.picker-item:active {
  background-color: #f8f9fa;
}

.picker-item-text {
  font-size: 32rpx;
  color: #333333;
}

/* 选中项样式 */
.picker-item.selected {
  background-color: rgba(39, 174, 96, 0.05);
}

.picker-item.selected .picker-item-text {
  color: #27AE60;
  font-weight: bold;
}