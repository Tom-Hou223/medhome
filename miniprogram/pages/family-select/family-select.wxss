.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-top: calc(var(--status-bar-height) + 88rpx);
}

.content {
  padding: 32rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.family-list {
  margin-bottom: 40rpx;
}

.family-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.family-info {
  flex: 1;
}

.family-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.family-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.role-tag {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.role-tag.admin {
  background: #fff3e0;
  color: #ff9800;
}

.role-tag.member {
  background: #e3f2fd;
  color: #2196f3;
}

.member-count {
  font-size: 24rpx;
  color: #999;
}

.empty-container {
  padding: 120rpx 0;
  text-align: center;
}

.empty-tips {
  font-size: 28rpx;
  color: #999;
  margin-top: 32rpx;
}

.action-buttons {
  margin-top: 60rpx;
}

.dialog-content {
  padding: 32rpx;
}

.dialog-tips {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
  text-align: center;
}
