.reminder-list-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.filter-bar {
  background: #fff;
  padding-top: calc(var(--status-bar-height) + 88rpx);
}

.content {
  padding: 24rpx 32rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.title-desc {
  font-size: 24rpx;
  color: #999;
}

.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.reminder-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.reminder-item.pending {
  border-left: 6rpx solid #27AE60;
}

.reminder-item.upcoming {
  border-left: 6rpx solid #999;
}

.reminder-item.completed {
  border-left: 6rpx solid #27AE60;
  opacity: 0.7;
}

.reminder-item.missed {
  border-left: 6rpx solid #e74c3c;
}

.reminder-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.time-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.reminder-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.medicine-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.member-name {
  font-size: 28rpx;
  color: #666;
}

.reminder-footer {
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.notes-text {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

.empty-state {
  margin-top: 120rpx;
}

.detail-dialog {
  padding: 32rpx;
}

.dialog-header {
  margin-bottom: 32rpx;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.dialog-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.dialog-footer {
  display: flex;
  gap: 16rpx;
}

.dialog-footer .van-button {
  flex: 1;
}