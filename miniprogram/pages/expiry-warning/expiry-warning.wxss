.expiry-warning-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.filter-bar {
  background: #fff;
  padding-top: calc(var(--status-bar-height) + 88rpx);
}

.content {
  padding: 24rpx 32rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.title-desc {
  font-size: 24rpx;
  color: #999;
}

.medicine-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.medicine-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.medicine-item.warning {
  border-left: 6rpx solid #f5a623;
}

.medicine-item.expired {
  border-left: 6rpx solid #e74c3c;
}

.medicine-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.medicine-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.medicine-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.info-text {
  font-size: 28rpx;
  color: #666;
}

.medicine-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.expiry-text {
  font-size: 28rpx;
  color: #999;
}

.empty-state {
  margin-top: 120rpx;
}

.detail-dialog {
  padding: 32rpx;
}

.dialog-header {
  margin-bottom: 32rpx;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.dialog-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.value.expiry {
  color: #e74c3c;
  font-weight: 600;
}

.dialog-footer {
  display: flex;
  gap: 16rpx;
}

.dialog-footer .van-button {
  flex: 1;
}