.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 1000;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #999;
}

.tab-bar-item.active .tab-text {
  color: #27AE60;
  font-weight: 600;
}

/* 老年模式样式 */
.tab-bar.senior-mode {
  height: 140rpx;
}

.tab-bar.senior-mode .tab-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 8rpx;
}

.tab-bar.senior-mode .tab-text {
  font-size: 32rpx;
  font-weight: 600;
}

/* 黑底黄字主题 */
.tab-bar.senior-mode.theme-yellow {
  background: #000000;
}

.tab-bar.senior-mode.theme-yellow .tab-text {
  color: #FFD700;
}

.tab-bar.senior-mode.theme-yellow .tab-bar-item.active .tab-text {
  color: #FFD700;
  font-weight: bold;
}

